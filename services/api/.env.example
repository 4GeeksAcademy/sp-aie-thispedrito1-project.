JWT_SECRET_KEY=change-this-in-local-env
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
SUPPLIERS_DB_PATH=./data/suppliers.db.json

# Password reset flow (AUTH-03)
# Lifetime of the signed password-reset token, in minutes (15-60 recommended).
RESET_TOKEN_EXPIRE_MINUTES=30
# Base URL of the frontend; used to build the reset link sent by email.
FRONTEND_BASE_URL=http://localhost:3000
# Transactional email (Resend). Get a key at https://resend.com/api-keys
RESEND_API_KEY=your-resend-api-key
# Verified sender. Resend's onboarding sender works without a custom domain in dev.
EMAIL_FROM=onboarding@resend.dev
